{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat | bash ~/.claude/hooks/block-no-verify.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat | bash ~/.claude/hooks/pre-push-secrets-scan.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat | bash ~/.claude/hooks/enforce-branch-policy.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat | bash ~/.claude/hooks/enforce-gitea-first.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "FileWrite|FileEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cat | bash ~/.claude/hooks/protect-critical-files.sh"
          }
        ]
      },
      {
        "matcher": "FileWrite|FileEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cat | bash ~/.claude/hooks/post-edit-lint-reminder.sh",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat | bash ~/.claude/hooks/changelog-reminder.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
